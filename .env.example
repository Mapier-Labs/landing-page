# Backend API (QR claim flow). No trailing slash — paths are joined as
# `${NEXT_PUBLIC_BACKEND_URL}/character/roll`, so a trailing slash would
# produce a double slash that the backend rejects as "Route not found".
NEXT_PUBLIC_BACKEND_URL=https://dev.api.mapier.ai

# Supabase (for waitlist)
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_URL=your-supabase-url
